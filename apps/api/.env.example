NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sistema_proveedores

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_in_production
REFRESH_TOKEN_EXPIRES_IN=30d

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Sistema Proveedores <noreply@example.com>"

STORAGE_BUCKET=sistema-proveedores-uploads
STORAGE_KEY=
STORAGE_SECRET=
STORAGE_REGION=us-east-1
