{
  "expo": {
    "name": "Sistema Proveedores",
    "slug": "sistema-proveedores",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sistema-proveedores",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "15.1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1D6F42"
      }
    }
  }
}
